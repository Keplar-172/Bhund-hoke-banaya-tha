# Docker ignore file
# Prevents unnecessary files from being copied to Docker image

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/
env/
ENV/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs (we'll create fresh in container)
*.log
logs/

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
!README.md
docs/

# Test files
tests/
.pytest_cache/
.coverage
htmlcov/

# Development files
docker-compose.override.yml
.dockerignore

# Build artifacts
dist/
build/
*.egg-info/

# Large data files (optional - uncomment if you don't need them in image)
# Match data/*.xlsx
# Match data/*.csv
