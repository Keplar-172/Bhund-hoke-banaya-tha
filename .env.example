# IPL Fantasy League 2026 - Environment Configuration
# Copy this file to .env and fill in your values

# ══════════════════════════════════════════════════════════════
# REQUIRED SETTINGS
# ══════════════════════════════════════════════════════════════

# RapidAPI Key for Cricbuzz API (required for fetching match data)
# Get your key from: https://rapidapi.com/cricketapi/api/cricbuzz-cricket
RAPIDAPI_KEY=your_rapidapi_key_here

# Secret key for session management (MUST BE UNIQUE IN PRODUCTION)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ══════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════

# Environment: development or production
ENVIRONMENT=development

# ══════════════════════════════════════════════════════════════
# WEB SERVER SETTINGS
# ══════════════════════════════════════════════════════════════

# Server host (use 0.0.0.0 to accept external connections)
HOST=0.0.0.0

# Server port
PORT=8000

# Auto-reload on code changes (set to false in production)
RELOAD=true

# ══════════════════════════════════════════════════════════════
# SECURITY SETTINGS (Production)
# ══════════════════════════════════════════════════════════════

# Rate limiting (requests per minute per IP)
RATE_LIMIT=60

# CORS allowed origins (comma-separated, use * for all)
# Example: https://wizzlebin.com,https://www.wizzlebin.com
CORS_ORIGINS=*

# Enable HTTPS redirect (set to true in production with SSL)
FORCE_HTTPS=false

# ══════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE=logs/app.log

# ══════════════════════════════════════════════════════════════
# OPTIONAL: DATABASE (Future Enhancement)
# ══════════════════════════════════════════════════════════════

# DATABASE_URL=postgresql://user:password@localhost/dbname
